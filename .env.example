# AgentGroup – environment variables
# Copy to .env and fill in your keys. Never commit .env to git.

# GitHub
GITHUB_TOKEN=ghp_...

# LLM providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
MISTRAL_API_KEY=...
XAI_API_KEY=xai-...
COHERE_API_KEY=...

# Ollama (local or cloud)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web search tool (optional – uses Tavily)
SEARCH_API_KEY=tvly-...
