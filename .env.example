# ── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
MISTRAL_API_KEY=...
XAI_API_KEY=xai-...
COHERE_API_KEY=...

# Ollama (local models – no API key needed if running on localhost)
OLLAMA_BASE_URL=http://localhost:11434

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token with repo scope (read + write)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ── Telegram (optional) ───────────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather and add it to your group
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=-1001234567890

# ── Tools ─────────────────────────────────────────────────────────────────────
# Tavily web search (https://tavily.com)
SEARCH_API_KEY=tvly-...

# ── Live chat server ──────────────────────────────────────────────────────────
# Ports used by run_local.py (change if needed)
LIVE_CHAT_PORT=7860
GRADIO_PORT=7861
